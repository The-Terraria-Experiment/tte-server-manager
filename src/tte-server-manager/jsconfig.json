{
	"compilerOptions": {
		"target": "es2022",
		"module": "es2022",
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"skipLibCheck": true,
		"types": ["vite/client"]
	},
	"include": ["src/**/*.js", "src/**/*.d.ts", "src/**/*.vue"],
	"exclude": ["dist", "node_modules"]
}